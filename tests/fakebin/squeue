#!/usr/bin/env bash
# Fake squeue: simulates job state transitions.
# Emits the comma-delimited, header-less format the backend now requests
# (--format=%i,%T --noheader). '|' was a shell-pipe hazard over real SSH.
#   FAKEBIN_SQUEUE_STATE: PD | R | "" (empty/unset -> not in queue)
#   Default state if unset: R
JOBID="${FAKEBIN_SBATCH_JOBID:-12345}"

if [[ -z "${FAKEBIN_SQUEUE_STATE+x}" ]]; then
    STATE="R"
else
    STATE="${FAKEBIN_SQUEUE_STATE}"
fi

if [[ -z "$STATE" ]]; then
    # Job has left the queue — print nothing.
    exit 0
fi

echo "${JOBID},${STATE}"
exit 0
